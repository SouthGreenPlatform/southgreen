      <script type="text/javascript">
        
        var activeitem = 1;
        var lastitemvisible = 4;
        var totalitems = 5;
        var totalitemsvisible = 4;
        var pctdone = 0;
        var negmargin = -(100/totalitemsvisible);
        var animating = false;
        var animatingbody = false;
        
        function progress() {
          if(pctdone >= 100) {
            $('.c-heading').find('.bar').width(0);
            var nextitem = activeitem++;
            if(activeitem > totalitems) {
              var nextitem = 1;
              activeitem = 1;
            }
            pctdone = 0;
            
            if(animatingbody == false) {
              animatingbody = true;
              var outgoing = $('.c-body:visible');
              $('.c-body:visible').animate({
                left: '-100px',
                right: '100px',
                opacity: 0
              }, 400, function() {
                $(outgoing).css('left', 0);
                $(outgoing).css('right', 0);
                $(outgoing).removeClass('active');
                $(outgoing).css('opacity', 1);
              });
              setTimeout(function() {
                $('.c-body-'+activeitem).css('opacity', 0);
                $('.c-body-'+activeitem).css('right', '-100px');
                $('.c-body-'+activeitem).css('left', '100px');
                $('.c-body-'+activeitem).addClass('active');
                $('.c-body-'+activeitem).animate({
                  left: '0px',
                  right: '0px',
                  opacity: 1
                }, 500, function() {
                  animatingbody = false;
                });
              }, 300);
            }
          }
          $('.c-heading').removeClass('active');
          $('.c-heading-'+activeitem).addClass('active');
          $('.c-heading-'+activeitem).find('.bar').width(pctdone+'%');
          pctdone = pctdone+0.2;
          if(activeitem > lastitemvisible) {
            lastitemvisible = activeitem;
            if(animating == false) {
              animating = true;
              $('.c-heading:first').parent().animate({
                marginLeft: negmargin*(lastitemvisible-totalitemsvisible)+'%'
              }, 500, function() {
                animating = false;
              });
            }
          }
          if(activeitem == 1) {
            lastitemvisible = totalitemsvisible;
            if(animating == false) {
              animating = true;
              $('.c-heading:first').parent().animate({
                marginLeft: 0
              }, 500, function() {
                animating = false;
              });
            }
          }
        }
        
        setInterval(function() {
          
          progress();
          
        }, 20);
        
        $('.c-heading').on('click', function() {
          pctdone = 0;
          $('.c-heading-'+activeitem).find('.bar').width(pctdone+'%');
          activeitem = $(this).data('id');
          nextitem = $(this).data('id');
          $('.c-heading').removeClass('active');
          $('.c-heading-'+activeitem).addClass('active');
          $('.c-body').removeClass('active');
          $('.c-body-'+activeitem).addClass('active');
        });
        
      </script>

